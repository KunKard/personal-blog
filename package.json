{
  "name": "personal-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-dev.mjs && npm run dev:restore && next dev",
    "dev:restore": "node scripts/restore-api.mjs",
    "prebuild": "npm run dev:remove-api && npx velite",
    "build": "cross-env NEXT_STATIC_EXPORT=true next build",
    "postbuild": "node scripts/restore-api.mjs",
    "dev:remove-api": "node scripts/remove-api.mjs",
    "start": "next start",
    "lint": "eslint",
    "velite": "velite"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@uiw/react-md-editor": "^4.1.1",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.25",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.4.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "velite": "^0.2.0"
  }
}
